{
  "selection_mode": "exclude_all",
  "include": [
    ".editorconfig",
    ".gitignore",
    "go.mod"
  ],
  "exclude": [],
  "prune": [
    ".git/",
    ".venv/",
    "__pycache__/",
    "*.egg-info/"
  ],
  "profiles": {
    "code": {
      "include": [
        "cmd/",
        "internal/"
      ]
    },
    "tests": {
      "include": [
        "test/"
      ]
    },
    "docs": {
      "include": [
        "docs/",
        "README.md"
      ]
    },
    "ops": {
      "include": [
        ".github",
        "install.sh"
      ]
    },
    "all": {
      "selection_mode": "include_all"
    }
  }
}
